# =============================================================================
# Shorty — Environment Variables
# Copy to .env and adjust values as needed: cp .env.example .env
# =============================================================================

# App
APP_ENV=local
APP_PORT_API=8080
APP_PORT_REDIRECT=8081
LOG_LEVEL=debug

# AWS (LocalStack)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566

# DynamoDB (LocalStack)
DYNAMODB_ENDPOINT=http://localstack:4566
DYNAMODB_REGION=us-east-1
DYNAMODB_TABLE_LINKS=shorty-links
DYNAMODB_TABLE_CLICKS=shorty-clicks
DYNAMODB_TABLE_USERS=shorty-users

# Redis
REDIS_ADDR=redis:6379

# SQS
SQS_ENDPOINT=http://localstack:4566
SQS_QUEUE_URL=http://localstack:4566/000000000000/click-events.fifo

# Auth (Cognito — leave empty for local dev)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
JWT_SECRET=local-dev-secret-change-in-prod

# Security
IP_HASH_SALT=local-dev-salt-change-in-prod

# Telemetry (requires docker-compose.infra.yml)
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=shorty

# Rate limits
RATE_LIMIT_REDIRECT_PER_MIN=200
RATE_LIMIT_CREATE_PER_HOUR=5

# Feature flags
SAFE_BROWSING_API_KEY=
