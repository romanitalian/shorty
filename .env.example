# =============================================================================
# Shorty — Environment Variables
# Copy to .env and adjust values as needed: cp .env.example .env
#
# Two supported modes:
#   1. Docker Compose stack (`make dev-up`)
#        — docker-compose.yml already bakes sensible defaults into the `api`
#          service's `environment:` block, so a .env file is *optional*.
#        — override values here if you need to tweak ports, logging, etc.
#
#   2. Native host (`make run-api`)
#        — this file is the source of truth; use localhost:* endpoints.
# =============================================================================

# App
APP_ENV=local
APP_PORT_API=8080
APP_PORT_REDIRECT=8081
LOG_LEVEL=debug

# Run the Lambda handler as a plain HTTP server (see cmd/api/main.go).
LOCAL_MODE=true

# Public base URL used in short_url responses.
SHORT_BASE_URL=http://localhost:8080

# AWS (LocalStack)
#   - Native host: http://localhost:4566
#   - Docker Compose: http://localstack:4566 (set in docker-compose.yml)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566

# DynamoDB tables — names read by cmd/api/main.go
LINKS_TABLE=shorty-links
CLICKS_TABLE=shorty-clicks
USERS_TABLE=shorty-users

# Legacy aliases (kept for tooling that still references DYNAMODB_TABLE_*)
DYNAMODB_ENDPOINT=http://localhost:4566
DYNAMODB_REGION=us-east-1
DYNAMODB_TABLE_LINKS=shorty-links
DYNAMODB_TABLE_CLICKS=shorty-clicks
DYNAMODB_TABLE_USERS=shorty-users

# Redis
REDIS_ADDR=localhost:6379

# SQS
SQS_ENDPOINT=http://localhost:4566
SQS_QUEUE_URL=http://localhost:4566/000000000000/click-events.fifo
CLICKS_QUEUE_URL=http://localhost:4566/000000000000/click-events.fifo

# Auth (Cognito — leave empty for local dev; local authenticator accepts any Bearer token)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
JWT_SECRET=local-dev-secret-change-in-prod

# Security
IP_HASH_SALT=local-dev-salt-change-in-prod
CSRF_SECRET=local-dev-csrf-change-in-prod

# Telemetry (requires docker-compose.infra.yml)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=shorty

# Rate limits
RATE_LIMIT_REDIRECT_PER_MIN=200
RATE_LIMIT_CREATE_PER_HOUR=5

# Feature flags
SAFE_BROWSING_API_KEY=
