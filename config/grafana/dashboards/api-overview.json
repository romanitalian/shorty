{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (handler) (rate(shorty_redirects_total{service=\"shorty-api\"}[5m]))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(shorty_links_created_total[5m]))",
          "legendFormat": "POST /api/v1/links (creates)",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Latency by Endpoint (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.3 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(shorty_redirect_duration_seconds_bucket{service=\"shorty-api\"}[5m])) by (le, handler))",
          "legendFormat": "p99 {{handler}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate by Endpoint (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          },
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (handler) (rate(shorty_redirects_total{service=\"shorty-api\", status=~\"5..\"}[5m])) / sum by (handler) (rate(shorty_redirects_total{service=\"shorty-api\"}[5m])) * 100",
          "legendFormat": "5xx {{handler}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active Links Count",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(shorty_links_created_total) - sum(shorty_links_deleted_total or vector(0))",
          "legendFormat": "Active Links",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "title": "Links Created by Plan",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (plan) (rate(shorty_links_created_total[5m]))",
          "legendFormat": "{{plan}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Rate Limiter Hits",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (type, plan) (rate(shorty_rate_limit_hits_total[5m]))",
          "legendFormat": "{{type}} / {{plan}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["shorty", "api", "lambda"],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Shorty - API Overview",
  "uid": "shorty-api-overview",
  "version": 1
}
