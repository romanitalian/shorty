{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "DynamoDB",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "DynamoDB Consumed RCU vs Provisioned",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "shorty_dynamodb_consumed_read_capacity_units",
          "legendFormat": "Consumed RCU - {{table}}",
          "refId": "A"
        },
        {
          "expr": "shorty_dynamodb_provisioned_read_capacity_units",
          "legendFormat": "Provisioned RCU - {{table}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "DynamoDB Consumed WCU vs Provisioned",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "shorty_dynamodb_consumed_write_capacity_units",
          "legendFormat": "Consumed WCU - {{table}}",
          "refId": "A"
        },
        {
          "expr": "shorty_dynamodb_provisioned_write_capacity_units",
          "legendFormat": "Provisioned WCU - {{table}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "DynamoDB Throttled Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (table) (rate(shorty_dynamodb_throttled_requests_total[5m]))",
          "legendFormat": "Throttles - {{table}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Redis",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },
    {
      "title": "Redis Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "shorty_redis_memory_used_bytes",
          "legendFormat": "Used Memory",
          "refId": "A"
        },
        {
          "expr": "shorty_redis_memory_max_bytes",
          "legendFormat": "Max Memory",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Redis Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 18 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 4000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "shorty_redis_connected_clients",
          "legendFormat": "Connected Clients",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Redis Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 18 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "shorty_redis_keyspace_hits_total / (shorty_redis_keyspace_hits_total + shorty_redis_keyspace_misses_total)",
          "legendFormat": "Hit Rate",
          "refId": "A"
        }
      ]
    },
    {
